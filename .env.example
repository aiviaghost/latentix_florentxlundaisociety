# Anthropic API Key (required for persona synthesis and simulation)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=...

# Server Configuration
PORT=3001

# Client Configuration (for CORS)
CLIENT_URL=http://localhost:5173

# When "true", Society Builder applies pipeline updates live from POST /society/search SSE.
# Otherwise the stream is buffered and the scripted client replay runs after the graph returns.
VITE_PIPELINE_LIVE=

# Optional: override API base (default /api via Vite proxy)
# VITE_API_URL=http://localhost:3001/api

# GEMINI (https://aistudio.google.com/api-keys)
GEMINI_API_KEY=...
